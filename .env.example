TELEGRAM_BOT_TOKEN=123456:replace-with-your-bot-token

# Optional: comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone who can message the bot.
ALLOWED_USER_IDS=

# Optional: HTTP timeout in seconds for Cloudflare WARP registration.
WARP_API_TIMEOUT=20

# Optional: uncomment when your server needs a proxy to reach Telegram or Cloudflare.
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
